---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha384-F5mDE5e6tGK7itOzPz7ZMyTsrBROINfNKSTvsRsdJwXClJh8VzFVv5ByxigDzqG+" crossorigin="anonymous">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		font-family: "JetBrains Mono";
		color: white;
	}
	html {
		background-size: 224px;
	}

	body {
		background-image: url("/background.gif");
		/* Reemplaza 'ruta/de/la/imagen.jpg' con la ruta de tu imagen */
		background-repeat: repeat;
		/* Evita que la imagen se repita */
		background-attachment: fixed;

		color: white;
	}
</style>
