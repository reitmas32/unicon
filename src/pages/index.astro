---
import Layout from "../layouts/Layout.astro";
import SimpleButton from "../components/SimpleButton.astro";
import HomeBody from "../components/HomeBody.astro";

---

<Layout title="Unicon">
	<main>
		<img
            class="astro-a"
            src="/background.png" 
            alt="Unicon the best event" 
        />
		<HomeBody>

		</HomeBody>
		<ul role="list" class="link-card-grid">

			<SimpleButton
				href="/in-process"
				lable="Comprar Ticket"
				info="Learn how Astro works and explore the official API docs."
				position="top-right"
			/>
			<SimpleButton
				href="/in-process"
				lable="¿Que queremos?"
				info="Learn how Astro works and explore the official API docs."
				position="bottom-left"
			/>
			<SimpleButton
				href="/in-process"
				lable="Llamado a la accion"
				info="Learn how Astro works and explore the official API docs."
				position="bottom-right"
			/>
		</ul>
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: white;
		font-size: 20px;
		line-height: 1.6;
	}

	.astro-a {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -1;
}
	h1 {
		font-size: 4rem;
		font-weight: 700;
		line-height: 1;
		text-align: center;
		margin-bottom: 1em;
	}
	.text-gradient {
		background-image: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-size: 400%;
		background-position: 0%;
	}
	.instructions {
		margin-bottom: 2rem;
		border: 1px solid rgba(var(--accent-light), 25%);
		background: linear-gradient(
			rgba(var(--accent-dark), 66%),
			rgba(var(--accent-dark), 33%)
		);
		padding: 1.5rem;
		border-radius: 8px;
	}
	.instructions code {
		font-size: 0.8em;
		font-weight: bold;
		background: rgba(var(--accent-light), 12%);
		color: rgb(var(--accent-light));
		border-radius: 4px;
		padding: 0.3em 0.4em;
	}
	.instructions strong {
		color: rgb(var(--accent-light));
	}
	.link-card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(24ch, 1fr));
		gap: 2rem;
		padding: 0;
	}
</style>
